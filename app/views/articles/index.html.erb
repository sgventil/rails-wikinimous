  <div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center bg-light">
      <%= link_to "Wikinimous", articles_path, class: "text-secondary fs-5" %>
      <%= link_to "New Article", new_article_path, class: "text-secondary" %>
    </div>
  </div>

<div class="container">
  <div class="row">
    <div class="col-sm-8 col-sm-offset-2">
        <% @articles.each do |article| %>
          <div class="article">
            <h2 class="lh-sm"><%= link_to article.title, article_path(article), class: "text-decoration-none link-hover" %></h2>
            <p class="fw-bold lh-base"><%= article.content %></p>
          </div>
        <% end %>
    </div>
  </div>
</div>

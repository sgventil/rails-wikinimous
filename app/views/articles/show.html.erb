  <div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center bg-light">
      <%= link_to "Wikinimous", articles_path, class: "text-secondary fs-5" %>
      <%= link_to "New Article", new_article_path, class: "text-secondary" %>
    </div>
  </div>

<div class="container">
  <div class="row">
    <div class="col-sm-8 col-sm-offset-2">
        <div class="article">
          <h2><%= @article.title %>
          <%= link_to edit_article_path(@article) do %>
            <span><i class="fa-solid fa-pencil fa-xs"></i></span>
          <% end %>
          <%= link_to article_path(@article), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' } do %>
            <span><i class="fa-solid fa-trash fa-xs"></i></span>
          <% end %>
          </h2>
          <%= @article.content %>
    </div>
  </div>
</div>
